---
import "../styles/global.css";
import AppShell from "../components/AppShell.astro";
import { copy, type Language } from "../lib/site-copy";

const langParam = Astro.url.searchParams.get("lang");
const lang: Language = langParam === "en" ? "en" : "es";
const emailCopy = copy[lang].email;
const pageTitle =
  lang === "es" ? "Kichi - entrega de correos" : "Kichi - email delivery";

const fallbackNotConfigured =
  lang === "es" ? emailCopy.notConfigured : emailCopy.notConfigured;
const smtpUser = import.meta.env.PUBLIC_SMTP_USER ?? fallbackNotConfigured;
const smtpFrom = import.meta.env.PUBLIC_SMTP_FROM ?? fallbackNotConfigured;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={emailCopy.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={emailCopy.title} />
  </head>
  <body class="app-body">
    <AppShell lang={lang} currentPath="/email">
      <div class="w-full max-w-6xl space-y-6">
        <section class="space-y-2">
          <h1
            id="email-title"
            class="text-3xl font-semibold leading-tight tracking-tight sm:text-4xl"
          >
            {emailCopy.title}
          </h1>
          <p
            id="email-batch"
            class="mono text-xs uppercase tracking-[0.22em] text-(--muted)"
          >
            {emailCopy.batchLabel}: KCH-2024-EVT-089
          </p>
        </section>

        <section class="app-glass rounded border border-(--line) px-5 py-4">
          <div class="flex flex-wrap items-center gap-6">
            <div>
              <p id="email-config-title" class="app-label">
                {emailCopy.configTitle}
              </p>
            </div>
            <div class="flex flex-col gap-1">
              <span id="email-config-user" class="mono text-xs text-(--muted)">
                {emailCopy.configUser}
              </span>
              <span class="mono text-sm text-(--ink)">{smtpUser}</span>
            </div>
            <div class="flex flex-col gap-1">
              <span id="email-config-from" class="mono text-xs text-(--muted)">
                {emailCopy.configFrom}
              </span>
              <span class="mono text-sm text-(--ink)">{smtpFrom}</span>
            </div>
          </div>
        </section>

        <div
          class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]"
        >
          <div class="space-y-6">
            <section class="app-glass rounded border border-(--line) p-6">
              <div class="flex items-start justify-between">
                <div>
                  <p id="email-status-label" class="app-label">
                    {emailCopy.statusLabel}
                  </p>
                  <div class="mt-2 flex items-center gap-2">
                    <span
                      class="h-2 w-2 rounded-full bg-(--signal) animate-pulse"
                    >
                    </span>
                    <span
                      id="email-status-value"
                      class="mono text-xs uppercase tracking-[0.22em] text-(--ink)"
                    >
                      {emailCopy.statusValue}
                    </span>
                  </div>
                </div>
                <div class="text-right">
                  <span class="text-3xl font-semibold text-(--ink)">65%</span>
                </div>
              </div>
              <div
                class="mt-5 h-2 w-full overflow-hidden rounded-full bg-[#e6e6e6]"
              >
                <div class="h-full w-[65%] bg-(--signal)"></div>
              </div>
              <div
                class="mt-4 flex flex-wrap items-center justify-between gap-3 text-xs text-(--muted)"
              >
                <span id="email-progress-completed">
                  {emailCopy.progressCompleted}
                </span>
                <span id="email-progress-remaining">
                  {emailCopy.progressRemaining}
                </span>
              </div>
            </section>

            <section
              class="app-glass overflow-hidden rounded border border-(--line)"
            >
              <div
                class="flex items-center justify-between border-b border-(--line) px-5 py-4"
              >
                <h3 id="email-log-title" class="app-label text-(--ink)">
                  {emailCopy.logTitle}
                </h3>
                <button
                  id="email-log-toggle"
                  class="app-label text-(--signal)"
                  type="button"
                >
                  {emailCopy.logToggleMore}
                </button>
              </div>
              <div id="email-log-list" class="space-y-3 bg-white/70 px-5 py-4">
                <div
                  data-email-item
                  class="flex items-start gap-3 rounded border border-(--line) bg-white/90 p-3"
                >
                  <svg
                    class="app-icon text-(--signal)"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M9 12l2 2l4-4"></path>
                    <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                  </svg>
                  <div>
                    <p class="text-sm text-(--ink)">
                      Entregado: Carlos Mendoza
                    </p>
                    <p class="mono text-xs text-(--muted)">10:42:15 - 250 OK</p>
                  </div>
                </div>
                <div
                  data-email-item
                  class="flex items-start gap-3 rounded border border-(--line) bg-white/90 p-3"
                >
                  <svg
                    class="app-icon text-(--signal)"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M9 12l2 2l4-4"></path>
                    <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                  </svg>
                  <div>
                    <p class="text-sm text-(--ink)">Entregado: Ana Silva</p>
                    <p class="mono text-xs text-(--muted)">10:42:12 - 250 OK</p>
                  </div>
                </div>
                <div
                  data-email-item
                  class="flex items-start gap-3 rounded border border-(--line) bg-white/90 p-3"
                >
                  <svg
                    class="app-icon text-(--signal)"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M9 12l2 2l4-4"></path>
                    <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                  </svg>
                  <div>
                    <p class="text-sm text-(--ink)">Entregado: Luis Robles</p>
                    <p class="mono text-xs text-(--muted)">10:42:05 - 250 OK</p>
                  </div>
                </div>
                <div
                  data-email-item
                  class="flex items-start gap-3 rounded border border-[#fecaca] bg-[#fef2f2] p-3"
                >
                  <svg
                    class="app-icon text-[#991b1b]"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M12 2a10 10 0 1 1 0 20a10 10 0 0 1 0-20z"></path>
                    <path d="M12 7v6"></path>
                    <path d="M12 16h.01"></path>
                  </svg>
                  <div>
                    <p class="text-sm text-[#991b1b]">Error: Maria Garcia</p>
                    <p class="mono text-xs text-(--muted)">
                      10:42:01 - SMTP Timeout
                    </p>
                  </div>
                </div>
                <div
                  data-email-item
                  class="flex items-start gap-3 rounded border border-(--line) bg-white/90 p-3"
                >
                  <svg
                    class="app-icon text-(--signal)"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M9 12l2 2l4-4"></path>
                    <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                  </svg>
                  <div>
                    <p class="text-sm text-(--ink)">
                      Entregado: Maria Fernanda
                    </p>
                    <p class="mono text-xs text-(--muted)">10:41:52 - 250 OK</p>
                  </div>
                </div>
                <div
                  data-email-item
                  class="flex items-start gap-3 rounded border border-(--line) bg-white/90 p-3"
                >
                  <svg
                    class="app-icon text-(--signal)"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M9 12l2 2l4-4"></path>
                    <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                  </svg>
                  <div>
                    <p class="text-sm text-(--ink)">Entregado: Ana Maria</p>
                    <p class="mono text-xs text-(--muted)">10:41:45 - 250 OK</p>
                  </div>
                </div>
                <div
                  data-email-item
                  class="flex items-start gap-3 rounded border border-(--line) bg-white/90 p-3"
                >
                  <svg
                    class="app-icon text-(--signal)"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M9 12l2 2l4-4"></path>
                    <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                  </svg>
                  <div>
                    <p class="text-sm text-(--ink)">Entregado: Jorge Ruiz</p>
                    <p class="mono text-xs text-(--muted)">10:41:32 - 250 OK</p>
                  </div>
                </div>
                <div
                  data-email-item
                  class="flex items-start gap-3 rounded border border-(--line) bg-white/90 p-3"
                >
                  <svg
                    class="app-icon text-(--signal)"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M9 12l2 2l4-4"></path>
                    <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                  </svg>
                  <div>
                    <p class="text-sm text-(--ink)">Entregado: Sofia Vega</p>
                    <p class="mono text-xs text-(--muted)">10:41:10 - 250 OK</p>
                  </div>
                </div>
                <div
                  data-email-item
                  class="flex items-start gap-3 rounded border border-(--line) bg-white/90 p-3"
                >
                  <svg
                    class="app-icon text-(--signal)"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M9 12l2 2l4-4"></path>
                    <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                  </svg>
                  <div>
                    <p class="text-sm text-(--ink)">Entregado: Diego Perez</p>
                    <p class="mono text-xs text-(--muted)">10:40:55 - 250 OK</p>
                  </div>
                </div>
              </div>
            </section>
          </div>

          <aside class="space-y-6">
            <section class="app-glass rounded border border-(--line) p-5">
              <h3 id="email-summary-title" class="app-label text-(--ink)">
                {emailCopy.summaryTitle}
              </h3>
              <div class="mt-4 space-y-3 text-sm">
                <div
                  class="flex items-center justify-between border-b border-(--line) pb-2"
                >
                  <span id="email-summary-total" class="text-(--muted)">
                    {emailCopy.summaryTotal}
                  </span>
                  <span class="font-semibold text-(--ink)">250</span>
                </div>
                <div
                  class="flex items-center justify-between border-b border-(--line) pb-2"
                >
                  <span id="email-summary-sent" class="text-(--muted)">
                    {emailCopy.summarySent}
                  </span>
                  <span class="font-semibold text-(--signal)">162</span>
                </div>
                <div
                  class="flex items-center justify-between border-b border-(--line) pb-2"
                >
                  <span id="email-summary-pending" class="text-(--muted)">
                    {emailCopy.summaryPending}
                  </span>
                  <span class="font-semibold text-(--ink)">85</span>
                </div>
                <div class="flex items-center justify-between">
                  <span id="email-summary-failed" class="text-(--muted)">
                    {emailCopy.summaryFailed}
                  </span>
                  <span class="font-semibold text-[#991b1b]">3</span>
                </div>
              </div>
            </section>

            <section class="app-glass rounded border border-(--line) p-5">
              <h3 id="email-controls-title" class="app-label text-(--ink)">
                {emailCopy.controlsTitle}
              </h3>
              <div class="mt-4 flex flex-col gap-3">
                <button
                  id="email-action-cancel"
                  class="btn-primary"
                  type="button"
                >
                  {emailCopy.actionCancel}
                </button>
                <button
                  id="email-action-retry"
                  class="btn-secondary"
                  type="button"
                >
                  {emailCopy.actionRetry}
                </button>
              </div>
            </section>
          </aside>
        </div>
      </div>
    </AppShell>
    <script is:inline define:vars={{ copy }}>
      (() => {
        const maxLogItems = 7;
        let showAll = false;

        const getLanguage = () => {
          const param = new URLSearchParams(window.location.search).get("lang");
          return param === "en" ? "en" : "es";
        };

        const updateLogVisibility = () => {
          const logList = document.getElementById("email-log-list");
          const toggle = document.getElementById("email-log-toggle");
          const items = logList
            ? Array.from(logList.querySelectorAll("[data-email-item]"))
            : [];

          items.forEach((item, index) => {
            const isVisible = showAll || index < maxLogItems;
            item.style.display = isVisible ? "" : "none";
          });

          const emailCopy = copy[getLanguage()].email;
          if (toggle) {
            toggle.textContent = showAll
              ? emailCopy.logToggleLess
              : emailCopy.logToggleMore;
          }
        };

        const applyLanguage = (language) => {
          const emailCopy = copy[language].email;
          const setText = (id, value) => {
            const element = document.getElementById(id);
            if (element) element.textContent = value;
          };

          setText("email-title", emailCopy.title);
          setText("email-batch", `${emailCopy.batchLabel}: KCH-2024-EVT-089`);
          setText("email-config-title", emailCopy.configTitle);
          setText("email-config-user", emailCopy.configUser);
          setText("email-config-from", emailCopy.configFrom);
          setText("email-status-label", emailCopy.statusLabel);
          setText("email-status-value", emailCopy.statusValue);
          setText("email-progress-completed", emailCopy.progressCompleted);
          setText("email-progress-remaining", emailCopy.progressRemaining);
          setText("email-log-title", emailCopy.logTitle);
          setText("email-summary-title", emailCopy.summaryTitle);
          setText("email-summary-total", emailCopy.summaryTotal);
          setText("email-summary-sent", emailCopy.summarySent);
          setText("email-summary-pending", emailCopy.summaryPending);
          setText("email-summary-failed", emailCopy.summaryFailed);
          setText("email-controls-title", emailCopy.controlsTitle);
          setText("email-action-cancel", emailCopy.actionCancel);
          setText("email-action-retry", emailCopy.actionRetry);

          updateLogVisibility();
        };

        const toggle = document.getElementById("email-log-toggle");
        if (toggle) {
          toggle.addEventListener("click", () => {
            showAll = !showAll;
            updateLogVisibility();
          });
        }

        applyLanguage(getLanguage());
        updateLogVisibility();

        window.addEventListener("language-change", (event) => {
          const detail = event.detail;
          if (!detail?.lang) return;
          applyLanguage(detail.lang);
        });
      })();
    </script>
  </body>
</html>
