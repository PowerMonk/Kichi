---
import "../styles/global.css";
import AppShell from "../components/AppShell.astro";
import EmailLog from "../components/EmailLog.astro";
import EmailProgressCard from "../components/EmailProgressCard.astro";
import EmailSummaryCard from "../components/EmailSummaryCard.astro";
import { copy, type Language } from "../lib/site-copy";

const langParam = Astro.url.searchParams.get("lang");
const lang: Language = langParam === "en" ? "en" : "es";
const emailCopy = copy[lang].email;
const pageTitle =
  lang === "es" ? "Kichi - entrega de correos" : "Kichi - email delivery";

const fallbackNotConfigured =
  lang === "es" ? emailCopy.notConfigured : emailCopy.notConfigured;
const smtpUser = import.meta.env.PUBLIC_SMTP_USER ?? fallbackNotConfigured;
const smtpFrom = import.meta.env.PUBLIC_SMTP_FROM ?? fallbackNotConfigured;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={emailCopy.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={emailCopy.title} />
  </head>
  <body class="app-body">
    <AppShell lang={lang} currentPath="/email">
      <div class="w-full max-w-6xl space-y-6">
        <section class="space-y-2">
          <h1
            id="email-title"
            class="text-3xl font-semibold leading-tight tracking-tight sm:text-4xl"
          >
            {emailCopy.title}
          </h1>
          <p
            id="email-batch"
            class="mono text-xs uppercase tracking-[0.22em] text-(--muted)"
          >
            {emailCopy.batchLabel}: KCH-2024-EVT-089
          </p>
        </section>

        <section class="app-glass rounded border border-(--line) px-5 py-4">
          <div class="flex flex-wrap items-center gap-6">
            <div>
              <p id="email-config-title" class="app-label">
                {emailCopy.configTitle}
              </p>
            </div>
            <div class="flex flex-col gap-1">
              <span id="email-config-user" class="mono text-xs text-(--muted)">
                {emailCopy.configUser}
              </span>
              <span class="mono text-sm text-(--ink)">{smtpUser}</span>
            </div>
            <div class="flex flex-col gap-1">
              <span id="email-config-from" class="mono text-xs text-(--muted)">
                {emailCopy.configFrom}
              </span>
              <span class="mono text-sm text-(--ink)">{smtpFrom}</span>
            </div>
          </div>
        </section>

        <div
          class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]"
        >
          <div class="space-y-6">
            <EmailProgressCard lang={lang} />
            <EmailLog lang={lang} />
          </div>

          <aside class="space-y-6">
            <EmailSummaryCard lang={lang} />

            <section class="app-glass rounded border border-(--line) p-5">
              <h3 id="email-controls-title" class="app-label text-(--ink)">
                {emailCopy.controlsTitle}
              </h3>
              <div class="mt-4 flex flex-col gap-3">
                <button
                  id="email-action-cancel"
                  class="btn-primary"
                  type="button"
                >
                  {emailCopy.actionCancel}
                </button>
                <button
                  id="email-action-retry"
                  class="btn-secondary"
                  type="button"
                >
                  {emailCopy.actionRetry}
                </button>
              </div>
            </section>
          </aside>
        </div>
      </div>
    </AppShell>
    <script is:inline define:vars={{ copy }}>
      (() => {
        const maxLogItems = 7;
        let showAll = false;
        const batchKey = "kichi-email-batch";

        const getLanguage = () => {
          const param = new URLSearchParams(window.location.search).get("lang");
          return param === "en" ? "en" : "es";
        };

        const setText = (id, value) => {
          const element = document.getElementById(id);
          if (element) element.textContent = value;
        };

        const formatTemplate = (template, params) =>
          Object.entries(params).reduce(
            (output, [key, value]) => output.replace(`{${key}}`, String(value)),
            template,
          );

        const readBatch = () => {
          try {
            const raw = window.localStorage.getItem(batchKey);
            return raw ? JSON.parse(raw) : null;
          } catch {
            return null;
          }
        };

        const buildLogItem = (entry, labels) => {
          const wrapper = document.createElement("div");
          wrapper.dataset.emailItem = "true";

          const isFailed = entry.status === "failed";
          wrapper.className = isFailed
            ? "flex items-start gap-3 rounded border border-[#fecaca] bg-[#fef2f2] p-3"
            : "flex items-start gap-3 rounded border border-(--line) bg-white/90 p-3";

          const icon = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "svg",
          );
          icon.setAttribute("viewBox", "0 0 24 24");
          icon.setAttribute("aria-hidden", "true");
          icon.classList.add(
            "app-icon",
            isFailed ? "text-[#991b1b]" : "text-(--signal)",
          );

          if (isFailed) {
            const iconCircle = document.createElementNS(
              "http://www.w3.org/2000/svg",
              "path",
            );
            iconCircle.setAttribute(
              "d",
              "M12 2a10 10 0 1 1 0 20a10 10 0 0 1 0-20z",
            );
            icon.appendChild(iconCircle);

            const iconLine = document.createElementNS(
              "http://www.w3.org/2000/svg",
              "path",
            );
            iconLine.setAttribute("d", "M12 7v6");
            icon.appendChild(iconLine);

            const iconDot = document.createElementNS(
              "http://www.w3.org/2000/svg",
              "path",
            );
            iconDot.setAttribute("d", "M12 16h.01");
            icon.appendChild(iconDot);
          } else {
            const iconPath = document.createElementNS(
              "http://www.w3.org/2000/svg",
              "path",
            );
            iconPath.setAttribute("d", "M9 12l2 2l4-4");
            icon.appendChild(iconPath);

            const iconCircle = document.createElementNS(
              "http://www.w3.org/2000/svg",
              "path",
            );
            iconCircle.setAttribute(
              "d",
              "M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z",
            );
            icon.appendChild(iconCircle);
          }

          const body = document.createElement("div");

          const title = document.createElement("p");
          title.className = isFailed
            ? "text-sm text-[#991b1b]"
            : "text-sm text-(--ink)";
          const nameOrEmail = entry.name || entry.email;
          title.textContent = `${
            isFailed ? labels.failed : labels.sent
          }: ${nameOrEmail}`;

          const subtitle = document.createElement("p");
          subtitle.className = "mono text-xs text-(--muted)";
          subtitle.textContent = isFailed
            ? entry.reason || ""
            : entry.email || "";

          body.append(title, subtitle);
          wrapper.append(icon, body);

          return wrapper;
        };

        const updateLogVisibility = () => {
          const logList = document.getElementById("email-log-list");
          const toggle = document.getElementById("email-log-toggle");
          const items = logList
            ? Array.from(logList.querySelectorAll("[data-email-item]"))
            : [];

          if (items.length <= maxLogItems) {
            showAll = false;
          }

          items.forEach((item, index) => {
            const isVisible = showAll || index < maxLogItems;
            item.style.display = isVisible ? "" : "none";
          });

          const emailCopy = copy[getLanguage()].email;
          if (toggle) {
            toggle.textContent = showAll
              ? emailCopy.logToggleLess
              : emailCopy.logToggleMore;
            toggle.style.display = items.length > maxLogItems ? "" : "none";
          }
        };

        const renderEmailBatch = () => {
          const batch = readBatch();
          const total = Number(batch?.targetCount ?? 0);
          const sent = Number(batch?.sentCount ?? 0);
          const failed = Number(batch?.failedCount ?? 0);
          const pending = Math.max(total - sent - failed, 0);
          const percent = total > 0 ? Math.round((sent / total) * 100) : 0;
          const emailCopy = copy[getLanguage()].email;

          const percentLabel = document.getElementById(
            "email-progress-percent",
          );
          if (percentLabel) percentLabel.textContent = `${percent}%`;

          const bar = document.getElementById("email-progress-bar");
          if (bar) bar.style.width = `${percent}%`;

          setText(
            "email-progress-completed",
            formatTemplate(emailCopy.progressCompleted, {
              sent,
              total,
            }),
          );
          setText(
            "email-progress-remaining",
            formatTemplate(emailCopy.progressRemaining, {
              eta: "--",
            }),
          );

          setText("email-summary-total-value", String(total));
          setText("email-summary-sent-value", String(sent));
          setText("email-summary-pending-value", String(pending));
          setText("email-summary-failed-value", String(failed));

          const logList = document.getElementById("email-log-list");
          if (logList) {
            logList.innerHTML = "";
            const logEntries = Array.isArray(batch?.log) ? batch.log : [];
            const labels = {
              sent: emailCopy.logSentLabel,
              failed: emailCopy.logFailedLabel,
            };
            logEntries.forEach((entry) => {
              logList.appendChild(buildLogItem(entry, labels));
            });
          }

          updateLogVisibility();
        };

        const applyLanguage = (language) => {
          const emailCopy = copy[language].email;
          setText("email-title", emailCopy.title);
          setText("email-batch", `${emailCopy.batchLabel}: KCH-2024-EVT-089`);
          setText("email-config-title", emailCopy.configTitle);
          setText("email-config-user", emailCopy.configUser);
          setText("email-config-from", emailCopy.configFrom);
          setText("email-status-label", emailCopy.statusLabel);
          setText("email-status-value", emailCopy.statusValue);
          setText("email-log-title", emailCopy.logTitle);
          setText("email-summary-title", emailCopy.summaryTitle);
          setText("email-summary-total", emailCopy.summaryTotal);
          setText("email-summary-sent", emailCopy.summarySent);
          setText("email-summary-pending", emailCopy.summaryPending);
          setText("email-summary-failed", emailCopy.summaryFailed);
          setText("email-controls-title", emailCopy.controlsTitle);
          setText("email-action-cancel", emailCopy.actionCancel);
          setText("email-action-retry", emailCopy.actionRetry);

          renderEmailBatch();
        };

        const toggle = document.getElementById("email-log-toggle");
        if (toggle) {
          toggle.addEventListener("click", () => {
            showAll = !showAll;
            updateLogVisibility();
          });
        }

        applyLanguage(getLanguage());

        window.addEventListener("language-change", (event) => {
          const detail = event.detail;
          if (!detail?.lang) return;
          applyLanguage(detail.lang);
        });
      })();
    </script>
  </body>
</html>
