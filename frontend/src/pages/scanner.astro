---
import "../styles/global.css";
import AppShell from "../components/AppShell.astro";
import { copy, type Language } from "../lib/site-copy";

const langParam = Astro.url.searchParams.get("lang");
const lang: Language = langParam === "en" ? "en" : "es";
const scannerCopy = copy[lang].scanner;
const pageTitle = lang === "es" ? "Kichi - escaner" : "Kichi - scanner";
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={scannerCopy.readySubtitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={scannerCopy.readySubtitle} />
  </head>
  <body class="app-body">
    <AppShell lang={lang} currentPath="/scanner">
      <div class="flex w-full flex-col items-start gap-6 xl:flex-row xl:gap-8">
        <section class="flex w-full flex-1 flex-col items-center space-y-6">
          <div class="w-full">
            <h2
              id="scanner-title"
              class="text-2xl font-semibold tracking-tight text-(--ink)"
            >
              {scannerCopy.title}
            </h2>
            <div class="mt-2 flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-(--signal) animate-pulse"
              ></span>
              <span id="scanner-status" class="app-label">
                {scannerCopy.status}
              </span>
            </div>
          </div>

          <div
            class="app-glass relative flex aspect-4/3 w-full max-w-2xl flex-col items-center justify-center rounded border border-(--line) p-2"
          >
            <div
              class="pointer-events-none absolute inset-8 rounded-lg border-2 border-dashed"
              style="border-color: rgba(193, 18, 31, 0.3);"
            >
              <div
                class="absolute left-0 top-0 h-8 w-8 border-l-4 border-t-4 border-(--signal)"
              >
              </div>
              <div
                class="absolute right-0 top-0 h-8 w-8 border-r-4 border-t-4 border-(--signal)"
              >
              </div>
              <div
                class="absolute bottom-0 left-0 h-8 w-8 border-b-4 border-l-4 border-(--signal)"
              >
              </div>
              <div
                class="absolute bottom-0 right-0 h-8 w-8 border-b-4 border-r-4 border-(--signal)"
              >
              </div>
            </div>
            <svg
              class="mb-4 h-16 w-16 text-(--signal) opacity-80"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M4 7V4h3M20 7V4h-3M4 17v3h3M20 17v3h-3M7 12h10"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.6"></path>
            </svg>
            <p
              id="scanner-ready-title"
              class="text-xl font-semibold text-(--signal)"
            >
              {scannerCopy.readyTitle}
            </p>
            <p
              id="scanner-ready-subtitle"
              class="mt-2 max-w-md text-center text-sm text-(--muted)"
            >
              {scannerCopy.readySubtitle}
            </p>
          </div>

          <div
            class="app-glass w-full max-w-2xl rounded border border-(--signal) bg-white/70 p-6 shadow-[0_10px_30px_rgba(0,0,0,0.04)]"
          >
            <div
              class="mb-4 flex items-start justify-between border-b border-(--line) pb-4"
            >
              <div>
                <div class="mb-1 flex items-center gap-2">
                  <svg
                    class="app-icon text-(--signal)"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M9 12l2 2l4-4"></path>
                    <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                  </svg>
                  <span
                    id="scanner-latest-status"
                    class="app-label text-(--signal)"
                  >
                    {scannerCopy.latestStatus}
                  </span>
                </div>
                <h3
                  id="scanner-latest-title"
                  class="text-xl font-semibold text-(--ink)"
                >
                  {scannerCopy.latestTitle}
                </h3>
              </div>
              <div
                class="mono rounded border border-(--line) bg-(--paper-strong) px-3 py-1 text-xs text-(--muted)"
              >
                ID: #KCH-8829-A
              </div>
            </div>

            <div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
              <div>
                <p id="scanner-field-name" class="app-label mb-1">
                  {scannerCopy.fieldName}
                </p>
                <p class="text-base font-semibold text-(--ink)">
                  {scannerCopy.sampleName}
                </p>
              </div>
              <div>
                <p id="scanner-field-role" class="app-label mb-1">
                  {scannerCopy.fieldRole}
                </p>
                <span
                  class="inline-block rounded bg-(--ink) px-2 py-1 text-xs text-white"
                >
                  {scannerCopy.sampleRole}
                </span>
              </div>
              <div>
                <p id="scanner-field-company" class="app-label mb-1">
                  {scannerCopy.fieldCompany}
                </p>
                <p class="text-base text-(--ink)">
                  {scannerCopy.sampleCompany}
                </p>
              </div>
              <div>
                <p id="scanner-field-control" class="app-label mb-1">
                  {scannerCopy.fieldControl}
                </p>
                <p
                  class="mono inline-block rounded border border-(--line) bg-(--paper-strong) px-2 py-1 text-xs text-(--ink)"
                >
                  {scannerCopy.sampleControl}
                </p>
              </div>
            </div>
          </div>
        </section>

        <aside
          class="app-glass w-full shrink-0 rounded border border-(--line) xl:w-80 xl:sticky xl:top-10"
        >
          <div
            class="flex items-center justify-between border-b border-(--line) bg-white/70 px-4 py-3"
          >
            <h3 id="scanner-activity-title" class="app-label text-(--ink)">
              {scannerCopy.activityTitle}
            </h3>
            <svg
              class="app-icon text-(--muted)"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path d="M12 6v6l4 2"></path>
              <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
            </svg>
          </div>
          <div class="space-y-2 p-2">
            <div class="rounded border border-(--line) bg-white/80 p-3">
              <div class="mb-2 flex items-start justify-between">
                <span class="mono text-xs text-(--muted)">#KCH-8829-A</span>
                <span class="mono text-xs text-(--muted)">10:42:15</span>
              </div>
              <div class="flex items-center gap-2">
                <svg
                  class="app-icon text-(--signal)"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M9 12l2 2l4-4"></path>
                  <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                </svg>
                <span class="text-sm text-(--ink)"
                  >{scannerCopy.sampleName}</span
                >
              </div>
            </div>
            <div class="rounded border border-(--line) bg-white/80 p-3">
              <div class="mb-2 flex items-start justify-between">
                <span class="mono text-xs text-(--muted)">#KCH-7104-B</span>
                <span class="mono text-xs text-(--muted)">10:41:02</span>
              </div>
              <div class="flex items-center gap-2">
                <svg
                  class="app-icon text-(--signal)"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M9 12l2 2l4-4"></path>
                  <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                </svg>
                <span class="text-sm text-(--ink)">Ana Silva</span>
              </div>
            </div>
            <div class="rounded border border-(--line) bg-white/80 p-3">
              <div class="mb-2 flex items-start justify-between">
                <span class="mono text-xs text-(--muted)">#KCH-3391-C</span>
                <span class="mono text-xs text-(--muted)">10:38:45</span>
              </div>
              <div class="flex items-center gap-2">
                <svg
                  class="app-icon text-(--signal)"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M9 12l2 2l4-4"></path>
                  <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                </svg>
                <span class="text-sm text-(--ink)">Luis Robles</span>
              </div>
            </div>
            <div class="rounded border border-[#fecaca] bg-[#fef2f2] p-3">
              <div class="mb-2 flex items-start justify-between">
                <span
                  id="scanner-activity-unknown"
                  class="mono text-xs font-semibold text-[#991b1b]"
                >
                  {scannerCopy.activityUnknown}
                </span>
                <span class="mono text-xs text-(--muted)">10:35:10</span>
              </div>
              <div class="flex items-center gap-2">
                <svg
                  class="app-icon text-[#991b1b]"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M12 2a10 10 0 1 1 0 20a10 10 0 0 1 0-20z"></path>
                  <path d="M12 7v6"></path>
                  <path d="M12 16h.01"></path>
                </svg>
                <span
                  id="scanner-activity-invalid"
                  class="text-sm text-[#991b1b]"
                >
                  {scannerCopy.activityInvalid}
                </span>
              </div>
            </div>
            <div class="rounded border border-(--line) bg-white/80 p-3">
              <div class="mb-2 flex items-start justify-between">
                <span class="mono text-xs text-(--muted)">#KCH-9921-A</span>
                <span class="mono text-xs text-(--muted)">10:30:05</span>
              </div>
              <div class="flex items-center gap-2">
                <svg
                  class="app-icon text-(--signal)"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M9 12l2 2l4-4"></path>
                  <path d="M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z"></path>
                </svg>
                <span class="text-sm text-(--ink)">Maria Fernanda</span>
              </div>
            </div>
          </div>
          <div
            class="border-t border-(--line) bg-white/70 px-3 py-3 text-center"
          >
            <button
              id="scanner-activity-action"
              class="app-label text-(--signal)"
            >
              {scannerCopy.activityAction}
            </button>
          </div>
        </aside>
      </div>
    </AppShell>
    <script is:inline define:vars={{ copy }}>
      (() => {
        const getLanguage = () => {
          const param = new URLSearchParams(window.location.search).get("lang");
          return param === "en" ? "en" : "es";
        };

        const applyLanguage = (language) => {
          const scanner = copy[language].scanner;
          document.documentElement.lang = language;

          const setText = (id, value) => {
            const element = document.getElementById(id);
            if (element) element.textContent = value;
          };

          setText("scanner-title", scanner.title);
          setText("scanner-status", scanner.status);
          setText("scanner-ready-title", scanner.readyTitle);
          setText("scanner-ready-subtitle", scanner.readySubtitle);
          setText("scanner-latest-status", scanner.latestStatus);
          setText("scanner-latest-title", scanner.latestTitle);
          setText("scanner-field-name", scanner.fieldName);
          setText("scanner-field-role", scanner.fieldRole);
          setText("scanner-field-company", scanner.fieldCompany);
          setText("scanner-field-control", scanner.fieldControl);
          setText("scanner-activity-title", scanner.activityTitle);
          setText("scanner-activity-action", scanner.activityAction);
          setText("scanner-activity-unknown", scanner.activityUnknown);
          setText("scanner-activity-invalid", scanner.activityInvalid);
        };

        applyLanguage(getLanguage());

        window.addEventListener("language-change", (event) => {
          const detail = event.detail;
          if (!detail?.lang) return;
          applyLanguage(detail.lang);
        });
      })();
    </script>
  </body>
</html>
