---
import "../styles/global.css";
import AppShell from "../components/AppShell.astro";
import ScannerLatestCard from "../components/ScannerLatestCard.astro";
import ScannerRecentActivity from "../components/ScannerRecentActivity.astro";
import { copy, type Language } from "../lib/site-copy";

const langParam = Astro.url.searchParams.get("lang");
const lang: Language = langParam === "en" ? "en" : "es";
const scannerCopy = copy[lang].scanner;
const pageTitle = lang === "es" ? "Kichi - escaner" : "Kichi - scanner";
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={scannerCopy.readySubtitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={scannerCopy.readySubtitle} />
  </head>
  <body class="app-body">
    <AppShell lang={lang} currentPath="/scanner">
      <div class="flex w-full flex-col items-start gap-6 xl:flex-row xl:gap-8">
        <section class="flex w-full flex-1 flex-col items-center space-y-6">
          <div class="w-full">
            <h2
              id="scanner-title"
              class="text-2xl font-semibold tracking-tight text-(--ink)"
            >
              {scannerCopy.title}
            </h2>
            <div class="mt-2 flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-(--signal) animate-pulse"
              ></span>
              <span id="scanner-status" class="app-label">
                {scannerCopy.status}
              </span>
            </div>
          </div>

          <ScannerLatestCard lang={lang} />
        </section>
        <ScannerRecentActivity lang={lang} />
      </div>
    </AppShell>
    <script is:inline define:vars={{ copy }}>
      (() => {
        const API_BASE =
          window.location.port === "4321" ? "http://localhost:3001" : "";
        const getLanguage = () => {
          const param = new URLSearchParams(window.location.search).get("lang");
          return param === "en" ? "en" : "es";
        };

        let showAllActivity = false;
        const maxActivityItems = 7;

        const updateActivityActionLabel = () => {
          const scanner = copy[getLanguage()].scanner;
          const action = document.getElementById("scanner-activity-action");
          if (!action) return;
          action.textContent = showAllActivity
            ? scanner.activityActionLess
            : scanner.activityAction;
        };

        const applyLanguage = (language) => {
          const scanner = copy[language].scanner;
          document.documentElement.lang = language;

          const setText = (id, value) => {
            const element = document.getElementById(id);
            if (element) element.textContent = value;
          };

          setText("scanner-title", scanner.title);
          setText("scanner-status", scanner.status);
          setText("scanner-ready-title", scanner.readyTitle);
          setText("scanner-ready-subtitle", scanner.readySubtitle);
          setText("scanner-latest-status", scanner.latestStatus);
          setText("scanner-latest-title", scanner.latestTitle);
          setText("scanner-uuid-label", scanner.uuidLabel);
          setText("scanner-field-name", scanner.fieldName);
          setText("scanner-field-role", scanner.fieldRole);
          setText("scanner-field-company", scanner.fieldCompany);
          setText("scanner-field-control", scanner.fieldControl);
          setText("scanner-activity-title", scanner.activityTitle);
          setText("scanner-activity-action", scanner.activityAction);
          setText("scanner-activity-unknown", scanner.activityUnknown);
          setText("scanner-activity-invalid", scanner.activityInvalid);
          updateActivityActionLabel();
        };

        applyLanguage(getLanguage());

        window.addEventListener("language-change", (event) => {
          const detail = event.detail;
          if (!detail?.lang) return;
          applyLanguage(detail.lang);
        });

        const latestStatus = document.getElementById("scanner-latest-status");
        const latestTitle = document.getElementById("scanner-latest-title");
        const latestUuid = document.getElementById("scanner-value-uuid");
        const latestCard = document.getElementById("scanner-latest-card");
        const latestIcon = document.getElementById("scanner-latest-icon");
        const valueName = document.getElementById("scanner-value-name");
        const valueRole = document.getElementById("scanner-value-role");
        const valueCompany = document.getElementById("scanner-value-company");
        const valueControl = document.getElementById("scanner-value-control");
        const activityList = document.getElementById("scanner-activity-list");

        let activityInitialized = false;
        let buffer = "";
        let lastInputAt = 0;
        let clearTimer = null;

        const formatTime = (iso) => {
          const date = new Date(iso);
          return date.toLocaleTimeString([], {
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
          });
        };

        const setLatestStatus = (text, tone) => {
          if (!latestStatus) return;
          latestStatus.textContent = text;
          latestStatus.classList.remove("text-(--signal)", "text-[#991b1b]");
          latestStatus.classList.add(
            tone === "error" ? "text-[#991b1b]" : "text-(--signal)",
          );
        };

        const setLatestAccent = (isFound) => {
          if (latestCard) {
            latestCard.classList.remove("border-[#16a34a]");
            if (isFound) {
              latestCard.classList.add("border-[#16a34a]");
            }
          }

          if (latestIcon) {
            latestIcon.classList.remove(
              "text-(--signal)",
              "text-[#991b1b]",
              "text-[#16a34a]",
            );
            latestIcon.classList.add("text-[#16a34a]");
          }
        };

        const updateActivityVisibility = () => {
          if (!activityList) return;
          const items = Array.from(activityList.children);
          if (items.length <= maxActivityItems) {
            showAllActivity = false;
          }
          items.forEach((item, index) => {
            const isVisible = showAllActivity || index < maxActivityItems;
            item.style.display = isVisible ? "" : "none";
          });
          const action = document.getElementById("scanner-activity-action");
          if (action) {
            action.style.display =
              items.length > maxActivityItems ? "" : "none";
          }
          updateActivityActionLabel();
        };

        const updateLatest = (record, scannedAt, isFound) => {
          const scanner = copy[getLanguage()].scanner;
          if (latestTitle) latestTitle.textContent = scanner.latestTitle;
          if (latestUuid) latestUuid.textContent = record.uuid;
          setLatestAccent(isFound);

          if (isFound) {
            if (valueName) valueName.textContent = record.name;
            if (valueRole) valueRole.textContent = record.role;
            if (valueCompany) valueCompany.textContent = record.company;
            if (valueControl) valueControl.textContent = record.controlNumber;
            setLatestStatus(scanner.latestStatus, "ok");
          } else {
            if (valueName) valueName.textContent = scanner.activityUnknown;
            if (valueRole) valueRole.textContent = "-";
            if (valueCompany) valueCompany.textContent = "-";
            if (valueControl) valueControl.textContent = "-";
            setLatestStatus(scanner.activityInvalid, "error");
          }
        };

        const addActivityItem = ({ uuid, name, scannedAt, isFound }) => {
          if (!activityList) return;

          if (!activityInitialized) {
            activityList.innerHTML = "";
            activityInitialized = true;
          }

          const wrapper = document.createElement("div");
          wrapper.className = isFound
            ? "rounded border border-(--line) bg-white/80 p-3 space-y-2"
            : "rounded border border-[#fecaca] bg-[#fef2f2] p-3 space-y-2";

          const uuidRow = document.createElement("div");
          uuidRow.className = `mono text-xs ${
            isFound ? "text-(--muted)" : "font-semibold text-[#991b1b]"
          }`;
          uuidRow.textContent = uuid;

          const body = document.createElement("div");
          body.className = "flex items-center gap-2";

          const icon = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "svg",
          );
          icon.setAttribute("viewBox", "0 0 24 24");
          icon.setAttribute("aria-hidden", "true");
          icon.classList.add("app-icon", "text-[#16a34a]");

          const iconPath = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "path",
          );
          iconPath.setAttribute("d", "M9 12l2 2l4-4");
          icon.appendChild(iconPath);

          const iconCircle = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "path",
          );
          iconCircle.setAttribute(
            "d",
            "M12 22a10 10 0 1 1 0-20a10 10 0 0 1 0 20z",
          );
          icon.appendChild(iconCircle);

          const nameSpan = document.createElement("span");
          nameSpan.className = isFound
            ? "text-sm text-(--ink)"
            : "text-sm text-[#991b1b]";
          nameSpan.textContent = name;

          body.append(icon, nameSpan);

          const timeRow = document.createElement("div");
          timeRow.className = "mono text-xs text-(--muted)";
          timeRow.textContent = formatTime(scannedAt);

          wrapper.append(uuidRow, body, timeRow);
          activityList.prepend(wrapper);
          updateActivityVisibility();
        };

        const handleScan = async (uuid) => {
          const cleaned = uuid.trim();
          if (!cleaned) return;

          try {
            const response = await fetch(`${API_BASE}/api/scan`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ uuid: cleaned }),
            });

            const payload = await response.json();

            if (!response.ok) {
              throw new Error(payload.error ?? "Scan failed");
            }

            const scannedAt = payload.scannedAt ?? new Date().toISOString();
            if (payload.found && payload.attendee) {
              updateLatest(
                {
                  uuid: payload.attendee.uuid,
                  name: payload.attendee.name,
                  role: payload.attendee.role,
                  company: payload.attendee.email,
                  controlNumber: payload.attendee.controlNumber,
                },
                scannedAt,
                true,
              );
              addActivityItem({
                uuid: payload.attendee.uuid,
                name: payload.attendee.name,
                scannedAt,
                isFound: true,
              });
            } else {
              const scanner = copy[getLanguage()].scanner;
              updateLatest(
                {
                  uuid: cleaned,
                  name: scanner.activityUnknown,
                  role: "-",
                  company: "-",
                  controlNumber: "-",
                },
                scannedAt,
                false,
              );
              addActivityItem({
                uuid: cleaned,
                name: scanner.activityUnknown,
                scannedAt,
                isFound: false,
              });
            }
          } catch (error) {
            const scanner = copy[getLanguage()].scanner;
            const scannedAt = new Date().toISOString();
            updateLatest(
              {
                uuid: cleaned,
                name: scanner.activityUnknown,
                role: "-",
                company: "-",
                controlNumber: "-",
              },
              scannedAt,
              false,
            );
            addActivityItem({
              uuid: cleaned,
              name: scanner.activityUnknown,
              scannedAt,
              isFound: false,
            });
          }
        };

        const handleKeydown = (event) => {
          const target = event.target;
          if (
            target &&
            (target instanceof HTMLInputElement ||
              target instanceof HTMLTextAreaElement)
          ) {
            return;
          }

          if (event.key === "Enter") {
            if (buffer.length > 0) {
              const scanValue = buffer;
              buffer = "";
              handleScan(scanValue);
            }
            return;
          }

          if (
            event.key.length !== 1 ||
            event.ctrlKey ||
            event.metaKey ||
            event.altKey
          ) {
            return;
          }

          const now = Date.now();
          if (now - lastInputAt > 500) {
            buffer = "";
          }

          buffer += event.key;
          lastInputAt = now;

          if (clearTimer) {
            window.clearTimeout(clearTimer);
          }

          clearTimer = window.setTimeout(() => {
            buffer = "";
          }, 600);
        };

        window.addEventListener("keydown", handleKeydown);

        updateActivityVisibility();

        const activityAction = document.getElementById(
          "scanner-activity-action",
        );
        if (activityAction) {
          activityAction.addEventListener("click", () => {
            showAllActivity = !showAllActivity;
            updateActivityVisibility();
          });
        }
      })();
    </script>
  </body>
</html>
