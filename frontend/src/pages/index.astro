---
import "../styles/global.css";

const processSteps = [
  { n: "01", t: "Upload", d: "XLSX or CSV for the current event batch." },
  { n: "02", t: "Map", d: "Match spreadsheet columns to Kichi fields." },
  { n: "03", t: "Generate", d: "One UUID and QR per attendee row." },
];

const sampleCodes = [
  { name: "Nora Ortega", control: "23104567", role: "Delegate" },
  { name: "Diego Mendez", control: "23104589", role: "Staff" },
  { name: "Iris Rojas", control: "23104614", role: "Speaker" },
  { name: "Liam Castillo", control: "23104630", role: "Volunteer" },
  { name: "Sara Kim", control: "23104677", role: "Delegate" },
  { name: "Mateo Park", control: "23104705", role: "Press" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Kichi - QR codes from your attendee list</title>
    <meta
      name="description"
      content="Drop an XLSX or CSV and generate one QR code per attendee with a local-first workflow."
    />
    <meta
      property="og:title"
      content="Kichi - QR codes from your attendee list"
    />
    <meta
      property="og:description"
      content="Turn any spreadsheet into per-attendee QR codes for events."
    />
  </head>

  <body>
    <div class="kichi-shell min-h-screen">
      <header class="glass-strip border-b border-(--line)">
        <div
          class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4"
        >
          <a href="/" class="text-2xl font-semibold tracking-tight">Kichi</a>
          <div
            class="mono hidden items-center gap-4 text-xs uppercase tracking-[0.2em] text-(--muted) sm:flex"
          >
            <span>v0.1</span>
            <span class="h-1 w-1 rounded-full bg-(--signal)"></span>
            <span>local-first</span>
          </div>
        </div>
      </header>

      <main class="mx-auto max-w-5xl px-5 py-10 sm:py-16">
        <section data-panel="source" class="panel is-active space-y-10">
          <section class="space-y-6">
            <p class="mono text-xs uppercase tracking-[0.3em] text-(--signal)">
              // step_01 - upload
            </p>
            <h1
              class="max-w-3xl text-4xl font-semibold leading-[1.05] tracking-tight sm:text-6xl"
            >
              Spreadsheet in.
              <br />
              <span class="mono text-(--signal)">QR codes</span> out.
            </h1>
            <p class="max-w-xl text-base text-(--muted) sm:text-lg">
              Kichi turns your attendee list into a unique QR code per row for
              check-ins, badges, and ticketing. Drop a file, map a couple of
              columns, ship the batch. No accounts, no friction.
            </p>
          </section>

          <section class="surface-card grid gap-6 p-6 lg:grid-cols-[1.5fr_1fr]">
            <div class="space-y-5">
              <div>
                <p
                  class="mono text-xs uppercase tracking-[0.23em] text-(--signal)"
                >
                  input_source
                </p>
                <h2 class="mt-2 text-2xl font-semibold tracking-tight">
                  Upload attendee spreadsheet
                </h2>
                <p class="mt-1 text-sm text-(--muted)">
                  CSV and XLSX are supported in V1.
                </p>
              </div>

              <input
                type="file"
                accept=".csv,.xlsx"
                class="upload-input mono text-sm"
              />

              <p class="text-sm text-(--muted)">
                For this first school congress deployment, control number is
                mandatory and used for QR filenames.
              </p>

              <div class="flex flex-wrap gap-3">
                <button type="button" class="btn-primary" data-go-to="map">
                  Continue to mapping
                </button>
              </div>
            </div>

            <div class="surface-inset space-y-4 p-5">
              <p
                class="mono text-xs uppercase tracking-[0.23em] text-(--signal)"
              >
                out_of_scope_v1
              </p>
              <h3 class="text-lg font-semibold">Google Sheet source</h3>
              <p class="text-sm text-(--muted)">
                Kept in the UI direction, but intentionally disabled for this
                first release. Local files only, deterministic runs.
              </p>
              <div class="border border-(--line) bg-white/70 p-4">
                <label class="field-label" for="sheet-url">Sheet URL</label>
                <input
                  id="sheet-url"
                  disabled
                  placeholder="Coming in a future version"
                  class="w-full border border-(--line) bg-white/80 px-3 py-2 text-sm text-(--muted) disabled:cursor-not-allowed"
                />
              </div>
            </div>
          </section>

          <section
            class="grid gap-px overflow-hidden border border-(--line) bg-(--line) sm:grid-cols-3"
          >
            {
              processSteps.map((item) => (
                <div class="bg-(--paper) p-6">
                  <p class="mono text-xs uppercase tracking-[0.25em] text-(--signal)">
                    {item.n}
                  </p>
                  <h3 class="mt-2 text-lg font-semibold">{item.t}</h3>
                  <p class="mt-1 text-sm text-(--muted)">{item.d}</p>
                </div>
              ))
            }
          </section>
        </section>

        <section data-panel="map" class="panel space-y-6">
          <div class="space-y-2">
            <p class="mono text-xs uppercase tracking-[0.3em] text-(--signal)">
              // step_02
            </p>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              Map your columns
            </h2>
            <p class="max-w-2xl text-sm text-(--muted)">
              Tell Kichi which columns contain name, email, and role. The event
              identifier is required for the active profile.
            </p>
          </div>

          <div class="surface-card grid gap-6 p-6 lg:grid-cols-[1.7fr_1fr]">
            <form class="grid gap-4">
              <div>
                <label class="field-label" for="col-name">Name column</label>
                <select id="col-name" class="field-select mono text-sm">
                  <option>full_name</option>
                  <option>name</option>
                </select>
              </div>
              <div>
                <label class="field-label" for="col-email">Email column</label>
                <select id="col-email" class="field-select mono text-sm">
                  <option>email</option>
                  <option>correo</option>
                </select>
              </div>
              <div>
                <label class="field-label" for="col-role">Role column</label>
                <select id="col-role" class="field-select mono text-sm">
                  <option>role</option>
                  <option>category</option>
                </select>
              </div>
              <div>
                <label class="field-label" for="col-control">
                  Event identifier (required now)
                </label>
                <select id="col-control" class="field-select mono text-sm">
                  <option>control_number</option>
                  <option>matricula</option>
                </select>
              </div>

              <div class="mt-1 flex flex-wrap gap-3">
                <button type="button" class="btn-secondary" data-go-to="source">
                  Back
                </button>
                <button type="button" class="btn-primary" data-go-to="results">
                  Generate codes
                </button>
              </div>
            </form>

            <aside class="surface-inset space-y-4 p-5">
              <p
                class="mono text-xs uppercase tracking-[0.24em] text-(--signal)"
              >
                flexible_event_tags
              </p>
              <p class="text-sm text-(--muted)">
                Future events can swap the required identifier and include
                custom tags without changing the core workflow.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="status-chip">control_number</span>
                <span class="status-chip">country</span>
                <span class="status-chip">sport</span>
                <span class="status-chip">team_code</span>
              </div>
            </aside>
          </div>
        </section>

        <section data-panel="results" class="panel space-y-6">
          <div class="space-y-2">
            <p class="mono text-xs uppercase tracking-[0.3em] text-(--signal)">
              // step_03
            </p>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              Codes generated
            </h2>
            <p class="max-w-2xl text-sm text-(--muted)">
              Click any tile to download a PNG, or export the whole batch as a
              ZIP.
            </p>
          </div>

          <div
            class="grid gap-px overflow-hidden border border-(--line) bg-(--line) sm:grid-cols-3"
          >
            <div class="bg-(--paper) p-5">
              <p
                class="mono text-xs uppercase tracking-[0.22em] text-(--muted)"
              >
                rows
              </p>
              <p class="mt-2 text-3xl font-semibold">156</p>
            </div>
            <div class="bg-(--paper) p-5">
              <p
                class="mono text-xs uppercase tracking-[0.22em] text-(--muted)"
              >
                qrs created
              </p>
              <p class="mt-2 text-3xl font-semibold">156</p>
            </div>
            <div class="bg-(--paper) p-5">
              <p
                class="mono text-xs uppercase tracking-[0.22em] text-(--muted)"
              >
                emails queued
              </p>
              <p class="mt-2 text-3xl font-semibold">156</p>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {
              sampleCodes.map((entry) => (
                <article class="qr-grid-card">
                  <div class="qr-mock" />
                  <p class="mt-3 text-sm font-semibold">{entry.name}</p>
                  <p class="mono mt-1 text-xs uppercase tracking-[0.2em] text-(--muted)">
                    {entry.control}
                  </p>
                  <p class="mt-2 text-xs uppercase tracking-[0.2em] text-(--signal)">
                    {entry.role}
                  </p>
                </article>
              ))
            }
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <button type="button" class="btn-primary">Download ZIP batch</button
            >
            <button type="button" class="btn-secondary"
              >Send sequential emails</button
            >
            <button type="button" class="btn-secondary" data-go-to="source">
              Reset workflow
            </button>
          </div>
        </section>
      </main>

      <footer class="mt-20 border-t border-(--line) bg-(--paper)/70">
        <div
          class="mono mx-auto flex max-w-5xl flex-col items-start justify-between gap-2 px-5 py-6 text-xs uppercase tracking-[0.2em] text-(--muted) sm:flex-row sm:items-center"
        >
          <span>// kichi - qr toolkit for events</span>
          <span>built for organizers who like sharp tools</span>
        </div>
      </footer>
    </div>

    <script is:inline>
      (() => {
        const allowedTargets = new Set(["source", "map", "results"]);
        const panels = Array.from(document.querySelectorAll("[data-panel]"));

        const setActivePanel = (target) => {
          if (!allowedTargets.has(target)) {
            return;
          }

          panels.forEach((panel) => {
            const isTarget = panel.getAttribute("data-panel") === target;
            panel.classList.toggle("is-active", isTarget);
          });
        };

        const wireNavigation = () => {
          document.querySelectorAll("[data-go-to]").forEach((control) => {
            control.addEventListener("click", () => {
              const target = control.getAttribute("data-go-to");
              if (!target) {
                return;
              }

              setActivePanel(target);
              window.scrollTo({ top: 0, behavior: "smooth" });
            });
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", wireNavigation, {
            once: true,
          });
        } else {
          wireNavigation();
        }
      })();
    </script>
  </body>
</html>
