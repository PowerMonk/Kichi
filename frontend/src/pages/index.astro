---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import TrustedPartners from "../components/TrustedPartners.astro";
import { copy, type Language } from "../lib/site-copy";

const langParam = Astro.url.searchParams.get("lang");
const lang: Language = langParam === "en" ? "en" : "es";
const landingCopy = copy[lang].landing;
const pageTitle = "Kichi - Spreadsheet in. QR batch out.";
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={landingCopy.heroSubtitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={landingCopy.heroSubtitle} />
  </head>
  <body>
    <div class="kichi-shell min-h-screen">
      <SiteHeader lang={lang} currentPath="/" />

      <main class="mx-auto max-w-5xl px-5 py-14 sm:py-20">
        <section class="max-w-4xl space-y-6 text-center sm:mx-auto">
          <h1
            id="hero-title"
            class="whitespace-pre-line mx-auto max-w-3xl text-5xl font-semibold leading-[0.95] tracking-tight sm:text-7xl"
          >
            {landingCopy.heroTitle}
          </h1>
          <p
            id="hero-subtitle"
            class="mx-auto max-w-2xl text-lg text-(--muted) sm:text-xl"
          >
            {landingCopy.heroSubtitle}
          </p>
          <div class="flex justify-center pt-2">
            <a
              id="hero-cta"
              class="btn-primary"
              href={`/generate?lang=${lang}`}
            >
              {landingCopy.cta}
            </a>
          </div>
        </section>

        <TrustedPartners lang={lang} />
      </main>
    </div>
    <script is:inline define:vars={{ copy }}>
      (() => {
        const getLanguage = () => {
          const param = new URLSearchParams(window.location.search).get("lang");
          return param === "en" ? "en" : "es";
        };

        const applyLanguage = (language) => {
          const landing = copy[language].landing;
          document.documentElement.lang = language;

          const heroTitle = document.getElementById("hero-title");
          const heroSubtitle = document.getElementById("hero-subtitle");
          const heroCta = document.getElementById("hero-cta");
          const trustedTitle = document.getElementById("trusted-title");

          if (heroTitle) heroTitle.textContent = landing.heroTitle;
          if (heroSubtitle) heroSubtitle.textContent = landing.heroSubtitle;
          if (heroCta) {
            heroCta.textContent = landing.cta;
            heroCta.setAttribute("href", `/generate?lang=${language}`);
          }
          if (trustedTitle) trustedTitle.textContent = landing.trusted;
        };

        applyLanguage(getLanguage());

        window.addEventListener("language-change", (event) => {
          const detail = event.detail;
          if (!detail?.lang) return;
          applyLanguage(detail.lang);
        });
      })();
    </script>
  </body>
</html>
